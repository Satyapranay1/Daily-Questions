class Solution {
    public int[] pivotArray(int[] nums, int pivot) {
        int n = nums.length;
        int[] ans = new int[n];
        int lessTPivot = 0,greaterTPivot = n - 1;
        for (int i = 0,j = n - 1; i < n; i++,j--){
            if (nums[i] < pivot){
                ans[lessTPivot++] = nums[i];
            }

            if (nums[j] > pivot){
                ans[greaterTPivot--] = nums[j];
            }
        }

        while (lessTPivot <= greaterTPivot){
            ans[lessTPivot++] = pivot;
        }

        return ans;
    }
}
